{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Kiwi",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#number"
		},
		{
			"include": "#octal"
		},
		{
			"include": "#binary"
		},
		{
			"include": "#hexadecimal"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#punctuation"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.number-sign.kiwi",
					"match": "#.*"
				},
				{
					"name": "comment.block.double-number-sign.kiwi",
					"begin": "/#",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.begin.kiwi"
						}
					},
					"end": "#/",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.comment.end.kiwi"
						}
					},
					"patterns": [
						{
							"name": "keyword.other.documentation.kiwi",
							"match": "@(summary|param|return|returns|throws|example|see|deprecated|author|version)\\b"
						},
						{
							"name": "punctuation.definition.documentation.kiwi",
							"match": "^\\s*---\\s*$"
						},
						{
							"match": ".+?",
							"name": "comment.content.kiwi"
						}
					]
				}
			]
		},
		"interpolation": {
			"name": "meta.embedded.line.kiwi",
			"begin": "\\$\\{",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.template-expression.begin.kiwi"
				}
			},
			"end": "\\}",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.template-expression.end.kiwi"
				}
			},
			"patterns": [
				{
					"include": "#keywords"
				},
				{
					"include": "#number"
				},
				{
					"include": "#octal"
				},
				{
					"include": "#binary"
				},
				{
					"include": "#hexadecimal"
				},
				{
					"include": "#operators"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.kiwi",
					"begin": "\"",
					"end": "\"",
					"captures": {
						"0": {
							"name": "punctuation.definition.string.begin.kiwi"
						},
						"1": {
							"name": "punctuation.definition.string.end.kiwi"
						},
						"2": {
							"name": "string.quoted.double.kiwi"
						}
					},
					"patterns": [
						{
							"name": "constant.character.escape.kiwi",
							"match": "\\\\(?:[nrt\"\\\\]|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
						},
						{
							"include": "#interpolation"
						}
					]
				},
				{
					"name": "string.quoted.single.kiwi",
					"begin": "'",
					"end": "'",
					"captures": {
						"0": {
							"name": "punctuation.definition.string.begin.kiwi"
						},
						"1": {
							"name": "punctuation.definition.string.end.kiwi"
						},
						"2": {
							"name": "string.quoted.single.kiwi"
						}
					},
					"patterns": [
						{
							"name": "constant.character.escape.kiwi",
							"match": "\\\\(?:[nrt\"\\\\]|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
						}
					]
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.special.this.kiwi",
					"match": "(?<=\\s|^)@(?=\\s|$)"
				},
				{
					"name": "variable.other.static.kiwi",
					"match": "@@[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"name": "variable.instance.kiwi",
					"match": "@[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"comment": "Function definition — highlight name as entity",
					"match": "\\b(fn|def)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": {
							"name": "keyword.control.kiwi"
						},
						"2": {
							"name": "entity.name.function.kiwi"
						}
					}
				},
				{
					"comment": "Struct definition — highlight name as type entity",
					"match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": {
							"name": "keyword.control.kiwi"
						},
						"2": {
							"name": "entity.name.type.kiwi"
						}
					}
				},
				{
					"comment": "Enum definition — highlight name as type entity",
					"match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": {
							"name": "keyword.control.kiwi"
						},
						"2": {
							"name": "entity.name.type.kiwi"
						}
					}
				},
				{
					"comment": "Package definition — highlight name as namespace entity",
					"match": "\\b(package)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": {
							"name": "keyword.control.kiwi"
						},
						"2": {
							"name": "entity.name.namespace.kiwi"
						}
					}
				},
				{
					"name": "keyword.control.kiwi",
					"match": "\\b(abstract|as|break|case|catch|const|def|do|enum|eprint|eprintln|else|elsif|emit|end|exit|export|finally|for|if|import|include|in|interface|fn|package|next|off|on|once|override|eval|pass|print|println|printxy|private|repeat|require|return|static|struct|throw|to|try|var|with|when|while|yield)\\b"
				},
				{
					"name": "storage.type.kiwi",
					"match": "\\b(any|boolean|bytes|date|float|generator|hashmap|integer|lambda|list|none|object|pointer|string)\\b"
				},
				{
					"name": "keyword.function.kiwi",
					"match": "\\b(all|append|begins_with|between|call|chars|chomp|clear|clone|concat|contains|count|day|dequeue|each|empty|ends_with|enqueue|filter|find|first|flatten|get|has_key|hex_bytes|hour|index|insert|is_a|join|keys|last|lastindex|lines|lowercase|ltrim|map|match|matches|matches_all|max|members|merge|millisecond|min|minute|month|ord|parameters|pop|pretty|push|reduce|remove|remove_at|replace|returns|reverse|rotate|rreplace|rsplit|rtrim|scan|second|set|shift|size|skip|slice|sort|split|substring|sum|swap|take|to_bytes|to_date|to_float|to_hex|to_integer|to_lambda|to_list|to_string|tokens|trim|truthy|type|unique|unshift|uppercase|values|year|zip)\\b"
				},
				{
					"name": "constant.language.boolean.kiwi",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.language.null.kiwi",
					"match": "\\bnull\\b"
				},
				{
					"name": "variable.other.kiwi",
					"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
				}
			]
		},
		"number": {
			"name": "constant.numeric.kiwi",
			"match": "\\b-?(0|[1-9]\\d*)(\\.\\d+)?([eE][+-]?\\d+)?\\b"
		},
		"octal": {
			"name": "constant.numeric.octal.kiwi",
			"match": "\\b0o[0-7]+\\b"
		},
		"binary": {
			"name": "constant.numeric.binary.kiwi",
			"match": "\\b0b[01]+\\b"
		},
		"hexadecimal": {
			"name": "constant.numeric.hexadecimal.kiwi",
			"match": "\\b0x[0-9a-fA-F]+\\b"
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.kiwi",
					"match": "\\+|-|\\*|\\/|=|==|!=|<|>|<=|>=|=<|&|\\||\\^|~|<<|>>|>>>|&&|and|or|not|\\|\\||!|\\+=|-=|\\*\\*|\\*\\*=|\\*=|%=|%|\\/=|&=|\\|=|\\^=|~=|<<=|>>=|&&=|\\|\\|=|\\?|\\?\\?|:|::|\\.\\."
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"match": "[\\(\\)\\[\\]\\{\\}]",
					"name": "punctuation.section.kiwi"
				},
				{
					"match": "[,:]",
					"name": "punctuation.separator.kiwi"
				},
				{
					"match": "\\.",
					"name": "punctuation.accessor.kiwi"
				}
			]
		}
	},
	"scopeName": "source.kiwi"
}
